{
  "name": "redditwrapper",
  "version": "2.0.0",
  "description": "Local Reddit keyword monitor with Aho-Corasick matching and Ollama auto-replies",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "build": "tsc -b",
    "start": "npm run build && node ./dist/server.js",
    "dev": "npm run build && node ./dist/server.js"
  },
  "keywords": ["reddit", "aho-corasick", "ollama"],
  "license": "ISC",
  "dependencies": {
    "ahocorasick": "^1.0.2",
    "axios": "^1.12.2",
    "dotenv": "^17.2.2",
    "express": "^5.1.0",
    "retry-axios": "^3.2.1"
  },
  "devDependencies": {
    "@types/ahocorasick": "^1.0.0",
    "@types/express": "^5.0.5",
    "@types/node": "^24.5.2",
    "typescript": "^5.9.3"
  }
}
