# Reddit API credentials (required for listening and posting replies)
# Create a "script" type app at https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=your_client_id
CLIENT_SECRET=your_client_secret
REDDIT_USER=your_reddit_username
REDDIT_PASS="your_reddit_password"


# Local Ollama (optional — reply generation fails gracefully if offline)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Server port (default 3001)
PORT=3001
//Product_Name is set to be the "Product" for which local model should generate text to promote
Product_Name="Product"